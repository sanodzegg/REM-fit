{% doc %}
  @prompt
    Create a side-by-side banner section approximately 200px high for the homepage. The banner should have two columns side by side: one with text content (heading, short description, and a call-to-action button/link) and one with an image. The section should link to an internal page (https://www.rem-fit.co.uk/pages/uk-sleep-statistics). All content (text, image, link URL, button label) should be customizable via theme editor settings. The design should be clean and modern, fitting a premium fitness/wellness brand aesthetic., Can you add A button to link to the article. Title the button - Read More
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-side-banner-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-side-banner-container-{{ ai_gen_id }} {
    display: flex;
    align-items: stretch;
    min-height: {{ block.settings.banner_height }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-side-banner-content-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: {{ block.settings.content_padding }}px;
    gap: {{ block.settings.content_gap }}px;
  }

  .ai-side-banner-heading-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 600;
    color: {{ block.settings.heading_color }};
    line-height: 1.2;
  }

  .ai-side-banner-description-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.5;
  }

  .ai-side-banner-buttons-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .ai-side-banner-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    transition: background-color 0.3s ease;
  }

  .ai-side-banner-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-side-banner-article-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.article_button_background }};
    color: {{ block.settings.article_button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    transition: background-color 0.3s ease;
  }

  .ai-side-banner-article-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.article_button_hover_background }};
    color: {{ block.settings.article_button_hover_text_color }};
  }

  .ai-side-banner-image-wrapper-{{ ai_gen_id }} {
    flex: 1;
    position: relative;
    overflow: hidden;
  }

  .ai-side-banner-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-side-banner-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-side-banner-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  @media screen and (max-width: 749px) {
    .ai-side-banner-container-{{ ai_gen_id }} {
      flex-direction: column;
      min-height: auto;
    }

    .ai-side-banner-content-{{ ai_gen_id }} {
      order: {{ block.settings.mobile_content_order }};
    }

    .ai-side-banner-image-wrapper-{{ ai_gen_id }} {
      min-height: 200px;
      order: {{ block.settings.mobile_image_order }};
    }

    .ai-side-banner-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-side-banner-description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.description_size }}px * 0.9);
    }

    .ai-side-banner-buttons-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-side-banner-button-{{ ai_gen_id }},
    .ai-side-banner-article-button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<side-banner-{{ ai_gen_id }}
  class="ai-side-banner-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-side-banner-container-{{ ai_gen_id }}">
    <div class="ai-side-banner-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-side-banner-heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h2>
      {% endif %}

      {% if block.settings.description != blank %}
        <div class="ai-side-banner-description-{{ ai_gen_id }}">
          {{ block.settings.description }}
        </div>
      {% endif %}

      {% if block.settings.button_text != blank and block.settings.button_link != blank or block.settings.article != blank %}
        <div class="ai-side-banner-buttons-{{ ai_gen_id }}">
          {% if block.settings.button_text != blank and block.settings.button_link != blank %}
            <a
              href="{{ block.settings.button_link }}"
              class="ai-side-banner-button-{{ ai_gen_id }}"
            >
              {{ block.settings.button_text }}
            </a>
          {% endif %}

          {% if block.settings.article != blank %}
            <a
              href="{{ block.settings.article.url }}"
              class="ai-side-banner-article-button-{{ ai_gen_id }}"
            >
              Read More
            </a>
          {% endif %}
        </div>
      {% endif %}
    </div>

    <div class="ai-side-banner-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 1000 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-side-banner-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-side-banner-image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>
  </div>
</side-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class SideBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('side-banner-{{ ai_gen_id }}', SideBanner{{ ai_gen_id }});
  })();
</script>

