        "product_page_accordion_hBnRQJ": {
          "type": "productPageAccordion",
          "settings": {
            "noMargin": true,
            "accCustomID": "",
            "heading": "Mattress Cover",
            "content": "custom",
            "metafieldNS": "global",
            "metafieldKey": "",
            "page": "",
            "customContent": "<p>Your mattress may arrive in the previous cover design while we transition to our updated cover. As part of our commitment to reducing waste and maintaining efficient production, we are currently using remaining stock of the previous cover before fully switching to the new design.</p><p>\n\nPlease be assured that the mattress inside is the exact model and specification advertised. The internal construction, materials, and comfort level are unchanged and fully consistent with the product description. To provide complete clarity, the outer packaging label will confirm the mattress model and specifications, ensuring you receive the correct product regardless of the cover design used during this transition period.</p>"
          }
        },
        "accordion_group_end_product": {
