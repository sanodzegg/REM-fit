            "metafieldKey": "",
            "page": "",
            "customContent": "<img src=\"https://cdn.shopify.com/s/files/1/0635/4432/8438/files/tmp_7f074b08-1cd2-4f7a-b8ae-75d4686847e0.png?v=1746188502\">"
