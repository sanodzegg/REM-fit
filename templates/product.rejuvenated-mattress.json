0)","subheading":"","subheadingColor":"rgba(0,0,0,0)","subheadingPosition":"above","headingAlignment":"center"}},"43f1d682-d71b-419e-b811-961fdf4019fb":{"type":"section__slider--adaptive","blocks":{"template--16769963688182__43f1d682-d71b-419e-b811-961fdf4019fb-1679385024965b93fb-0":{"type":"imageSlideAdaptive","settings":{"horizontalAlignment":"center","verticalAlignment":"bottom","padding":16,"contentSpacing":12,"backgroundColor":"rgba(0,0,0,0)","backgroundImage":"shopify:\/\/shop_images\/GEN-656REM-Fit500Dec224_900x_copy.jpg","backgroundPosition":"middle","overlayOpacity":0,"overlayColor":"#000000","slideURL":"","heading":"Open-Cell Memory Foam","headingColor":"rgba(0,0,0,0)","content":"<h3>Our unique open cell memory foam provides advanced temperature regulation and won't heat up like standard memory foam. Overheating during sleep is one of the key reasons for unexplained waking during the night, disturbing our sleep cycles and affecting our overall rest & recovery.<\/h3>","contentColor":"rgba(0,0,0,0)","button1Text":"","button1Link":"","button1Style":"primary","button1Type":"default","button2Text":"","button2Link":"","button2Style":"secondary","button2Type":"default"}},"a055b72c-51e3-49bb-aab8-f8d49bd805a4":{"type":"imageSlideAdaptive","settings":{"horizontalAlignment":"center","verticalAlignment":"bottom","padding":16,"contentSpacing":12,"backgroundColor":"rgba(0,0,0,0)","backgroundImage":"shopify:\/\/shop_images\/GEN-656REM-Fit500Dec225_900x_copy.jpg","backgroundPosition":"middle","overlayOpacity":0,"overlayColor":"#000000","slideURL":"","heading":"2000 Premium Pocket Springs","headingColor":"rgba(0,0,0,0)","content":"<h3>Through rigorous testing, our sleep researchers found that springs below 8cm in height provided inadequate support and failed to isolate partner movement. For undisturbed sleep & superior support the REM-Fit 500 Ortho mattress uses 2000 firm, premium pocket springs, 15cm tall.<\/h3>","contentColor":"rgba(0,0,0,0)","button1Text":"","button1Link":"","button1Style":"primary","button1Type":"default","button2Text":"","button2Link":"","button2Style":"secondary","button2Type":"default"}}},"block_order":["template--16769963688182__43f1d682-d71b-419e-b811-961fdf4019fb-1679385024965b93fb-0","a055b72c-51e3-49bb-aab8-f8d49bd805a4"],"disabled":true,"custom_css":["h2 {font-size: 32px;}","h3 {width: 50%; font-size: 20px; font-weight: normal; margin-left: auto; margin-right: auto;}"],"settings":{"displayFor":"display--both","layout":"default","nomargin":false,"height":0,"contentColor":"rgba(0,0,0,0)","autoplay":false,"animation":"none","delayAnimation":false}}},"order":["breadcrumbs","page","165039953600f29ad0","1650397646a3939c91","1650388362846adab0","section_video_text_QKEdkP","section_video_text_6XzC8w","1650389009e56c8d9c","165038925879f958a5","1656591160c364f95f","165659373710757dc8","1656595426e3fd5964","16510493383aef7fc3","1650400037410d6fbc","upsell","recommended","165659438112110f3d","0451c051-bbde-4cf9-b71f-eb05c8cb5ebb","16565944667026dd8b","1650439604269827d1","e8897670-f110-4585-885e-cb22237a5d95","16576199514e142ec2","43f1d682-d71b-419e-b811-961fdf4019fb"]}