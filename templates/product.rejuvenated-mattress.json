51-ab8c7ab08ca9","056f18ae-74b2-4a6d-9254-dd81b3c48fcb","c717c11c-8042-4501-8f30-6bc97b095243","c70f0641-b284-4e15-8035-d1376577615a","a2076594-efc9-4b5c-b250-499118e2913d"],"settings":{"displayFor":"display--both","layout":"default","nomargin":true,"scopedCSS":"","height":0,"padding":20,"lineMargin":20,"backgroundColor":"#ffffff","backgroundPosition":"middle","backgroundFilter":"none","backdropIntensity":50,"parallax":false,"backgroundPattern":false,"overlayOpacity":0,"overlayColor":"#000000","contentColor":"rgba(0,0,0,0)","horizontalAlignment":"center","verticalAlignment":"middle","maxContentWidth":100,"faqid":"","heading":"Comfort is in the detail","headingColor":"rgba(0,0,0,0)","subheading":"","subheadingColor":"rgba(0,0,0,0)","subheadingPosition":"above","headingAlignment":"center","textContent":""}},"1650400037410d6fbc":{"type":"section__faq","blocks":{"67e26df9-71b5-4fba-802f-11ff8e66920a":{"type":"accordion","settings":{"question":"<p>{{ product.metafields.my_fields.faq_question_1_firmness.value }}<\/p>","answer":"<p>{{ product.metafields.my_fields.faq_answer_1_firmness | metafield_tag }}<\/p>"}},"e295a5c8-ba15-4bd9-9399-ddd3fa1a54ea":{"type":"accordion","settings":{"question":"<p>How does the 30-night trial work?<\/p>","answer":"<p>We provide a risk-free sleep trial on all our mattresses. This allows you to sleep on a REM-Fit for 30-nights in the comfort of your own home and really put it to the test! There are no catches. If the mattress, for whatever reason doesn’t live up to your expectations, you can send it back for a full refund. There are no collection charges either! View more info here<\/p>"}},"cd3e7f05-b1cc-4cba-92e7-cdf0d8753331":{"type":"accordion","settings":{"question":"<p>How long does delivery take?<\/p>","answer":"<p>• *Free 1-3 days delivery to UK addresses<\/p><p>•2-Person delivery service | Room of choice<\/p><p>•Old mattress removal - additional extra<\/p><p>•Delivered rolled & bagged for your convenience<\/p>"}},"1b3add3b-1d0c-496e-8b7c-012119c467c5":{"type":"accordion","settings":{"question":"<p>Why are REM-Fit springs superior to your counterparts?<\/p>","answer":"<p>Unlike our counterparts we use tall pocket springs constructed from triple tempered steel. Each spring is contained within its own pocket of fabric which prevents the spring system from rubbing against each other, nothing worse than a squeaky mattress! Tall pocket springs compared to mini springs (only) provide superior support and will isolate partner disturbance movement more effectively. Don't worry about feeling the springs through the mattress, you can't, we place them deep beneath the top layers of the mattress so that they are never noticeable.<\/p>"}},"bd43cb38-2a19-462d-a024-c7b7982da5e8":{"type":"accordion","settings":{"question":"<p>What base can the mattress go on?<\/p>","answer":"<p>Thanks to the high-density foam layer of the mattress you can confidently use the mattress on any bed base including adjustable beds!<\/p>"}},"78169c0e-f3b9-46fd-9775-8bb2dd1e56cd":{"type":"accordion","settings":{"question":"<p>I have a bad back - will this mattress help?<\/p>","answer":"<p>As non-medical professionals we make no guarantees that the mattress will improve your back complaint. However, we have designed our mattress range with a focus on back support. We also receive lots of positive feedback from sleepers who have suffered with a bad back to discover that sleeping on a REM-Fit mattress has relieved their pain and enabled them to get a great night's rest.<\/p>"}}},"block_order":["67e26df9-71b5-4fba-802f-11ff8e66920a","e295a5c8-ba15-4bd9-9399-ddd3fa1a54ea","cd3e7f05-b1cc-4cba-92e7-cdf0d8753331","1b3add3b-1d0c-496e-8b7c-012119c467c5","bd43cb38-2a19-462d-a024-c7b7982da5e8","78169c0e-f3b9-46fd-9775-8bb2dd1e56cd"],"settings":{"displayFor":"display--both","layout":"default","nomargin":true,"scopedCSS":"","height":0,"padding":20,"lineMargin":20,"backgroundColor":"#ecf7fd","backgroundPosition":"middle","backgroundFilter":"none","backd