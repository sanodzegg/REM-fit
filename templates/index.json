    "section_content_D8h9ET": {
      "type": "section__content",
      "blocks": {
        "html_GF8AkX": {
          "type": "html",
          "settings": {
            "blockWidth": "col-md-12",
            "vertPadding": 12,
            "horPadding": 10,
            "horAlign": "center",
            "vertAlign": "middle",
            "html": "<div style=\"background:#f8f5fb;padding:52px 24px;\">\n  <div style=\"max-width:1100px;margin:0 auto;\">\n \n    <!-- Section heading -->\n    <div style=\"text-align:center;margin-bottom:36px;\">\n      <span style=\"display:inline-block;font-size:12px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#3f2155;background:#f0ebf5;padding:4px 12px;border-radius:4px;margin-bottom:12px;\">Original research</span>\n      <h2 style=\"font-size:clamp(22px,3vw,30px);font-weight:700;color:#3f2155;margin:0 0 10px;line-height:1.25;\">Sleep data you won't find anywhere else</h2>\n      <p style=\"font-size:15px;color:#666;margin:0 auto;max-width:540px;line-height:1.6;\">Three original datasets built from real UK sleepers — not industry surveys or manufacturer claims.</p>\n    </div>\n \n    <!-- Card grid -->\n    <div style=\"display:grid;grid-template-columns:repeat(3,1fr);gap:20px;\">\n \n      <!-- Card 1: UK Sleep Statistics -->\n      <a href=\"/pages/uk-sleep-statistics\" style=\"display:block;text-decoration:none;background:#ffffff;border:1px solid #e0d8ea;border-radius:12px;padding:28px 24px;transition:border-color 0.15s;\" onmouseover=\"this.style.borderColor='#3f2155'\" onmouseout=\"this.style.borderColor='#e0d8ea'\">\n        <div style=\"font-size:11px;font-weight:600;letter-spacing:0.07em;text-transform:uppercase;color:#7f68a0;margin-bottom:14px;\">UK Sleep Statistics 2026</div>\n        <div style=\"font-size:42px;font-weight:700;color:#3f2155;line-height:1;margin-bottom:10px;\">72%</div>\n        <div style=\"font-size:15px;font-weight:600;color:#1a1a1a;margin-bottom:10px;line-height:1.35;\">of Brits aren't getting enough sleep</div>\n        <div style=\"font-size:13px;color:#666;line-height:1.55;margin-bottom:20px;\">50+ facts about how Britain sleeps — insomnia rates, economic cost, regional differences, and more.</div>\n        <div style=\"display:flex;gap:16px;padding-top:16px;border-top:1px solid #e0d8ea;\">\n          <div style=\"text-align:center;flex:1;\">\n            <div style=\"font-size:17px;font-weight:700;color:#3f2155;\">£40bn</div>\n            <div style=\"font-size:11px;color:#888;margin-top:2px;line-height:1.3;\">annual cost of poor sleep to UK economy</div>\n          </div>\n          <div style=\"text-align:center;flex:1;border-left:1px solid #e0d8ea;\">\n            <div style=\"font-size:17px;font-weight:700;color:#3f2155;\">50+</div>\n            <div style=\"font-size:11px;color:#888;margin-top:2px;line-height:1.3;\">sleep statistics with sources</div>\n          </div>\n        </div>\n        <div style=\"margin-top:20px;font-size:13px;font-weight:600;color:#3f2155;\">Read the statistics →</div>\n      </a>\n \n      <!-- Card 2: UK Sleeper Preferences (NEW — featured) -->\n      <a href=\"/pages/uk-sleeper-preferences\" style=\"display:block;text-decoration:none;background:#3f2155;border:1px solid #3f2155;border-radius:12px;padding:28px 24px;transition:opacity 0.15s;\" onmouseover=\"this.style.opacity='0.93'\" onmouseout=\"this.style.opacity='1'\">\n        <div style=\"font-size:11px;font-weight:600;letter-spacing:0.07em;text-transform:uppercase;color:rgba(255,255,255,0.6);margin-bottom:14px;\">UK Sleeper Preferences 2026</div>\n        <div style=\"font-size:42px;font-weight:700;color:#ffffff;line-height:1;margin-bottom:10px;\">105,165</div>\n        <div style=\"font-size:15px;font-weight:600;color:#fff;margin-bottom:10px;line-height:1.35;\">UK mattress shoppers surveyed</div>\n        <div style=\"font-size:13px;color:rgba(255,255,255,0.7);line-height:1.55;margin-bottom:20px;\">How UK sleepers actually sleep — firmness preferences, sleep positions, temperature needs, and motion sensitivity.</div>\n        <div style=\"display:flex;gap:16px;padding-top:16px;border-top:1px solid rgba(255,255,255,0.2);\">\n          <div style=\"text-align:center;flex:1;\">\n            <div style=\"font-size:17px;font-weight:700;color:#fff;\">84%</div>\n            <div style=\"font-size:11px;color:rgba(255,255,255,0.6);margin-top:2px;line-height:1.3;\">want temperature regulation</div>\n          </div>\n          <div style=\"text-align:center;flex:1;border-left:1px solid rgba(255,255,255,0.2);\">\n            <div style=\"font-size:17px;font-weight:700;color:#fff;\">77%</div>\n            <div style=\"font-size:11px;color:rgba(255,255,255,0.6);margin-top:2px;line-height:1.3;\">report back pain</div>\n          </div>\n        </div>\n        <div style=\"margin-top:20px;font-size:13px;font-weight:600;color:#fff;\">Explore the data →</div>\n      </a>\n \n      <!-- Card 3: Back Pain & Mattresses (NEW) -->\n      <a href=\"/pages/back-pain-mattress-data\" style=\"display:block;text-decoration:none;background:#ffffff;border:1px solid #e0d8ea;border-radius:12px;padding:28px 24px;transition:border-color 0.15s;\" onmouseover=\"this.style.borderColor='#3f2155'\" onmouseout=\"this.style.borderColor='#e0d8ea'\">\n        <div style=\"font-size:11px;font-weight:600;letter-spacing:0.07em;text-transform:uppercase;color:#7f68a0;margin-bottom:14px;\">Back Pain & Mattresses 2026</div>\n        <div style=\"font-size:42px;font-weight:700;color:#3f2155;line-height:1;margin-bottom:10px;\">84.5%</div>\n        <div style=\"font-size:15px;font-weight:600;color:#1a1a1a;margin-bottom:10px;line-height:1.35;\">of firm mattress shoppers report back pain</div>\n        <div style=\"font-size:13px;color:#666;line-height:1.55;margin-bottom:20px;\">What 105,165 UK sleepers reveal about back pain, firmness, sleep position, and what actually helps.</div>\n        <div style=\"display:flex;gap:16px;padding-top:16px;border-top:1px solid #e0d8ea;\">\n          <div style=\"text-align:center;flex:1;\">\n            <div style=\"font-size:17px;font-weight:700;color:#3f2155;\">77%</div>\n            <div style=\"font-size:11px;color:#888;margin-top:2px;line-height:1.3;\">report back pain overall</div>\n          </div>\n          <div style=\"text-align:center;flex:1;border-left:1px solid #e0d8ea;\">\n            <div style=\"font-size:17px;font-weight:700;color:#3f2155;\">65.8%</div>\n            <div style=\"font-size:11px;color:#888;margin-top:2px;line-height:1.3;\">sleep on their side</div>\n          </div>\n        </div>\n        <div style=\"margin-top:20px;font-size:13px;font-weight:600;color:#3f2155;\">Read the research →</div>\n      </a>\n \n    </div>\n \n    <!-- Mobile responsive override -->\n    <style>\n      @media (max-width: 767px) {\n        .rf-research-grid { grid-template-columns: 1fr !important; }\n      }\n    </style>\n \n  </div>\n</div>",
            "customCSS": ""
          }
        }
