olor.value }}","heading":"<p><strong>30 Night Sleep Trial<\/strong><\/p>","content":"<p><br\/>Sleep on it, jump on it and everything in between - it's yours for 30 nights (100 nights if you buy it with a mattress) to fall in love with. If it's not right for you, we'll collect for free and refund you in full<\/p>","buttonText":"","buttonURL":"","openTab":false,"buttonStyle":"secondary","buttonType":"filled"}},"c71dd9df-6c7f-455f-b171-01803d743693":{"type":"columnIcon","settings":{"icon":"truck","iconSize":50,"iconColor":"{{ product.metafields.my_fields.product_page_color.value }}","heading":"<p><strong>Free 1-3 Days Delivery<\/strong><\/p>","content":"<p><br\/>Hassle free room of choice delivery, 3 hour time slot with 30 minute pre-arrival phone call. Next Day delivery if you order it separately.<\/p>","buttonText":"","buttonURL":"","openTab":false,"buttonStyle":"secondary","buttonType":"filled"}},"0c1ccfaa-f82e-4d02-af01-6e9772fa4cd2":{"type":"columnIcon","settings":{"icon":"shield-check","iconSize":50,"iconColor":"{{ product.metafields.my_fields.product_page_color.value }}","heading":"<p><strong>10 Year Guarantee<\/strong><\/p>","content":"<p><br\/>We're so confident in the build quality that we have included a 10-year full replacement guarantee at no extra cost - so you can sleep soundly for years!<\/p>","buttonText":"","buttonURL":"","openTab":false,"buttonStyle":"secondary","buttonType":"filled"}},"8f3e056c-e011-4547-9165-cc6a9bc87840":{"type":"columnIcon","settings":{"icon":"0-plus","iconSize":50,"iconColor":"{{ product.metafields.my_fields.product_page_color.value }}","heading":"<p><strong>0 Finance<\/strong><\/p>","content":"<p><br\/>Buy now, pay whilst you sleep. Finance your REM-Fit with Klarna. 0% APR financing. Apply at the checkout page.<\/p>","buttonText":"","buttonURL":"","openTab":false,"buttonStyle":"secondary","buttonType":"filled"}}},"block_order":["5bc6a7b1-962b-40bb-b3a9-9bd872ab6f8d","c71dd9df-6c7f-455f-b171-01803d743693","0c1ccfaa-f82e-4d02-af0