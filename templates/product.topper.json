es\/RF-Purple_bedding-01.png","imageSize":25,"heading":"<p><strong>Bedding-In<\/strong><\/p>","content":"<p><\/p><p>We request that you give your new REM-Fit mattress 30 nights to bed-in before you raise a return. This will give your body the right amounts of time to fully adjust <\/p>","buttonText":"","buttonURL":"","openTab":false,"buttonStyle":"secondary","buttonType":"filled"}},"cd2628ee-9b2d-4a70-8993-36a864e46b5f":{"type":"columnImage","settings":{"image":"shopify:\/\/shop_images\/RF-Purple_how-01.png","imageSize":25,"heading":"<p><strong>How to return?<\/strong><\/p>","content":"<p><\/p><p>How do I raise a return request? Simply email us at sales@rem-fit-accounts.co.uk or call 0121 3144264. Please notes, our live chat assistants cannot process return requests.<\/p>","buttonText":"","buttonURL":"","openTab":false,"buttonStyle":"secondary","buttonType":"filled"}}},"block_order":["09e73536-4510-4c85-8479-23bd3bca8f1f","6a001b90-55e2-432b-9160-ed8277956438","cdb79898-ca11-4880-a529-c9260e8ffd90","cd2628ee-9b2d-4a70-8993-36a864e46b5f"],"disabled":true,"settings":{"displayFor":"display--both","layout":"default","nomargin":true,"scopedCSS":"##scoped h2{\npadding-top:24px;\n}\n\n##scoped .middle{\nalign-items:baseline;\n}","customclass":"","customID":"nightrial","height":0,"padding":20,"lineMargin":0,"backgroundColor":"#ecf7fd","backgroundPosition":"middle","backgroundFilter":"none","backdropIntensity":50,"parallax":false,"backgroundPattern":false,"overlayOpacity":0,"overlayColor":"#000000","contentColor":"rgba(0,0,0,0)","horizontalAlignment":"center","verticalAlignment":"top","heading":"It's yours for 100 nights, to do as you please with it","headingColor":"rgba(0,0,0,0)","subheading":"","subheadingColor":"rgba(0,0,0,0)","subheadingPosition":"above","headingAlignment":"center","colHeight":0,"colGap":40,"textAlign":"center","contentAlign":"top","colCount":"col-md-3"}},"165659373710757dc8":{"type":"section__content","blocks":{"ea7c18e2-f4a3-45b5-9eff-c82f873fc66c":{"t