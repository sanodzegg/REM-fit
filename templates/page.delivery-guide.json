{"sections":{"banner":{"type":"banner--page","settings":{"layout":"boxed","height":100,"horizontalAlignment":"center","verticalAlignment":"middle","fontSize":"big","contentColor":"rgba(0,0,0,0)","fillColor":"rgba(0,0,0,0)","overlayOpacity":0,"overlayColor":"#000000"}},"content":{"type":"page","settings":{"layout":"default","enableShortcodes":false}},"section_image_picture_text_mzwqLg":{"type":"section__image-picture-text","blocks":{"title_9wFbRz":{"type":"title","settings":{"fullWidth":true,"content":"Important Delivery Information","textColor":"rgba(0,0,0,0)","fontFamily":"title","fontSize":"big"}},"rich_text_CTiwHn":{"type":"richText","settings":{"fullWidth":true,"maxBWidth":90,"content":"<p>Thank you once again for selecting our sleep products. We appreciate your choice! Your order will be dispatched shortly, but before that, we would like to provide you with some crucial information to ensure a smooth delivery process.<br\/><br\/><strong>It is essential to note that in the event of no one being present at the property on the scheduled delivery day, a redelivery fee of £30 will be applied. To avoid any inconvenience, please ensure that someone is available to receive the order upon its arrival.<\/strong><\/p><p><\/p>","detectLists":true,"textColor":"rgba(0,0,0,0)","fontFamily":"base","fontSize":"base"}}},"block_order":["title_9wFbRz","rich_text_CTiwHn"],"settings":{"displayFor":"display--both","layout":"default","nomargin":true,"scopedCSS":"","customID":"","height":0,"padding":0,"lineMargin":12,"backgroundColor":"rgba(0,0,0,0)","backgroundPosition":"middle","backgroundFilter":"none","backdropIntensity":50,"parallax":false,"backgroundPattern":false,"overlayOpacity":0,"overlayColor":"#000000","contentColor":"rgba(0,0,0,0)","horizontalAlignment":"start","verticalAlignment":"middle","imagePosition":"left","imageWidth":"6","image":"shopify:\/\/shop_images\/d1af7260-aa2c-482f-a41a-800c4e276c59.jpg","imageOverlayOpacity":0,"imageOverlayColor":"#000000"}},"section_content_JbLNGc":{"type":"section__content","blocks":{"rich_text_E99Pmt":{"type":"richText","settings":{"blockWidth":"col-md-12","vertPadding":12,"horPadding":4,"horAlign":"start","vertAlign":"middle","maxBWidth":100,"content":"<h2><strong>How the delivery works:<\/strong><\/h2><ul><li>You will soon be provided with a choice of delivery dates to choose from.<\/li><li>You will be given a 3-hour timeslot the day before delivery.<\/li><li>You will be provided live tracking so you can keep up to date with your delivery in real time.<\/li><li>The delivery drivers will call you when they are 30 minutes away.<\/li><li>Delivery is to room of choice.<\/li><\/ul><h2><\/h2><h2>3 step guide for a successful delivery<\/h2><p>For a fast and efficient delivery, we use Rhenus Logistics to deliver our mattresses. <br\/>Please watch this <a href=\"https:\/\/www.youtube.com\/watch?v=aXdkGHhhZqY&utm_source=Klaviyo&utm_medium=flow&utm_campaign=%C2%A330%20Failed%20Delivery%20Fee%20-%20Please%20Read&utm_id=R2bUbp&_kx=oDJEf_VhHUBOKl1KndiXlQ%3D%3D.Tk5uDL\"><strong>short info video <\/strong><\/a>to plan and prepare for your delivery.<\/p><p>Please be aware that failure to pay the redelivery charge will result in the cancellation of your order, with a refund issued minus £30. <br\/>We kindly request your cooperation in ensuring a successful delivery.<\/p>","detectLists":true,"textColor":"rgba(0,0,0,0)","fontFamily":"base","fontSize":"base"}},"button_6be3WE":{"type":"button","settings":{"blockWidth":"col-md-12","vertPadding":12,"horPadding":4,"horAlign":"start","vertAlign":"top","text":"Watch Delivery Instructions","url":"https:\/\/www.youtube.com\/watch?v=aXdkGHhhZqY&utm_source=Klaviyo&utm_medium=flow&utm_campaign=%C2%A330%20Failed%20Delivery%20Fee%20-%20Please%20Read&utm_id=R2bUbp&_kx=oDJEf_VhHUBOKl1KndiXlQ%3D%3D.Tk5uDL","icon":"","iconPosition":"icon--left","wideButton":false,"buttonStyle":"primary","buttonType":"default","fontSize":"base","fontFamily":"base","animation":"none","animationDuration