{%liquid
assign url = section.settings.defaultBackgroundImage  
if collection.image != nil and section.settings.useCollectionImage
assign url = collection.image
endif %}

{% capture layoutConfig %}{% render 'common-layout' with section as section %}{% endcapture %}

{% assign default = false %}
{% if url == nil and section.settings.fillColor contains 'rgba(0,0,0,0)' and section.settings.overlayOpacity == 0 %}
{% assign default = true %}
{% endif %}

<style>
#section-{{section.id}} {
    position: relative;
    {% if url != nil %}
    background-image: url({{url | img_url: '10x' }});
    background-size: cover;
    background-position: center center;
    {% endif %}
    background-color: {{section.settings.fillColor}};
    color: {% unless section.settings.contentColor contains 'rgba(0,0,0,0)' %}{{section.settings.contentColor}}{% else %}initial{% endunless %};
    min-height: {{section.settings.height}}px;
}

#section-{{section.id}} .section__row {
    z-index: 1;
}

{% if section.settings.overlayOpacity > 0 %}
#section-{{section.id}} .overlay {
    opacity: {{section.settings.overlayOpacity | times: 0.01}};
    background: {{section.settings.overlayColor}};
    z-index: 0;
}
{% endif %}
</style>

{% if template.name == 'product' or template.name == 'collection' %} 
<div class="prod-collection-list">
{% if settings.swiperCollectionBanner  %}
    {% assign banner-collection = settings.swiperCollectionBanner %}  
     {% if banner-collection != blank %}   
  		{% if [template.name].metafields.slider.product-image1 != blank or [template.name].metafields.slider.product-image2 != blank or [template.name].metafields.slider.product-image3 != blank or [template.name].metafields.slider.product-image4 != blank or [template.name].metafields.slider.product-image5 != blank or [template.name].metafields.slider.product-image6 != blank or [template.name].metafields.slider.product-image7 != blank or [template.name].metafields.slider.product-image8 != blank%}
       		{% render 'swiper-slider',template_name:template.name %}
  		{% endif %}
     {% endif %} 
  {% endif %} 
</div>
{% endif %}


{% if default %}
  <div class="row breadcrumbs__wrapper">
      <div class="layout__content breadcrumbs--default col-12">{% render 'breadcrumbs' %}</div>
  </div>
  <div id="section-{{section.id}}" 
  class="{% unless section.settings.contentColor contains 'rgba(0,0,0,0)' %}inherit{% endunless %} lazyload row banner layout__{{-layoutConfig}} {{section.settings.verticalAlignment}}">
    <div class="col-12 unflex section__row layout__content {{section.settings.horizontalAlignment}}">
      {% if section.settings.showTitle %}<h1 class="h-reset font__size--{{section.settings.fontSize}}">{{ collection.title }} {% if section.settings.showNumber %}(<span class="collection__total-items">{{collection.products_count}}</span>){% endif %}</h1>{% endif %}
      {% if section.settings.showDescription %}
        {% if section.settings.truncateReadMore %}
          <div class="collection__description">
            <div class="read-more-wrapper">
              <div class="read-more-content">{{ collection.description }}</div>
              <div class="read-more-fade"></div>
              <button type="button" class="read-more-btn" aria-expanded="false">Read more</button>
            </div>
          </div>
        {% else %}
          <div class="collection__description">
            {% if section.settings.truncateDesc > 0 %}
              {{ collection.description | truncate: section.settings.truncateDesc, '...' }}
            {% else %}
              {{ collection.description }}
            {% endif %}
          </div>
        {% endif %}
      {% endif %}
    </div>
  </div>
{% else %}
  <div id="section-{{section.id}}" 
  class="{% unless section.settings.contentColor contains 'rgba(0,0,0,0)' %}inherit{% endunless %} lazyload row banner layout__{{-layoutConfig}} {{section.settings.verticalAlignment}}" 
  {% if url != nil %}{% render 'background', image: url %}{% endif %}>
  {% if section.settings.overlayOpacity > 0 %}<div class="overlay"></div>{%endif%}
    <div class="col-12 unflex section__row layout__content {{section.settings.horizontalAlignment}}">
      {% if product.template_suffix == 'collection' %}
        <div class="breadcrumbs">{% render 'breadcrumbs' %}</div>
      {% endif %} 
      {% if section.settings.showTitle %}<h1 class="h-reset font__size--{{section.settings.fontSize}}">{{ collection.title }} {% if section.settings.showNumber %}(<span class="collection__total-items">{{collection.products_count}}</span>){% endif %}</h1>{% endif %}
      {% if section.settings.showDescription %}
        {% if section.settings.truncateReadMore %}
          <div class="collection__description">
            <div class="read-more-wrapper">
              <div class="read-more-content">{{ collection.description }}</div>
              <div class="read-more-fade"></div>
              <button type="button" class="read-more-btn" aria-expanded="false">Read more</button>
            </div>
          </div>
        {% else %}
          <div class="collection__description">
            {% if section.settings.truncateDesc > 0 %}
              {{ collection.description | truncate: section.settings.truncateDesc, '...' }}
            {% else %}
              {{ collection.description }}
            {% endif %}
          </div>
        {% endif %}
      {% endif %}
    </div>
  </div>
{% endif %}

<style>
  #section-{{ section.id }} .read-more-wrapper { position: relative; }
  #section-{{ section.id }} .read-more-content {
    max-height: 80px;
    overflow: hidden;
    transition: max-height 0.4s ease;
  }
  #section-{{ section.id }} .read-more-content.expanded { max-height: 2000px; }
  #section-{{ section.id }} .read-more-fade {
    position: absolute;
    bottom: 30px;
    left: 0;
    width: 100%;
    height: 60px;
    background: linear-gradient(to bottom, transparent, {{ section.settings.fillColor }});
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  #section-{{ section.id }} .read-more-fade.hidden { opacity: 0; }
  #section-{{ section.id }} .read-more-btn {
    background: none;
    border: none;
    color: inherit;
    font-weight: 600;
    cursor: pointer;
    padding: 8px 0;
    text-decoration: underline;
    font-size: inherit;
  }
  #section-{{ section.id }} .read-more-btn:hover { opacity: 0.7; }
</style>

<script>
  (function () {
    var MAX = 80;
    var wrapper = document.querySelector('#section-{{ section.id }} .read-more-wrapper');
    if (!wrapper || wrapper.dataset.rmReady) return;
    wrapper.dataset.rmReady = '1';


    var content = wrapper.querySelector('.read-more-content');
    var btn = wrapper.querySelector('.read-more-btn');
    var fade = wrapper.querySelector('.read-more-fade');

    if (!content || !btn || !fade) return;

    if (content.scrollHeight <= MAX) {
      btn.style.display = 'none';
      fade.style.display = 'none';
      content.style.maxHeight = 'none';
      return;
    }

    btn.addEventListener('click', function (e) {
      // product-list.liquid registers a document-level delegated click
      // handler on .read-more-btn. Stop the event here so that handler
      // doesn't re-toggle .expanded and cancel out this click.
      e.stopPropagation();
      var expanded = content.classList.toggle('expanded');
      fade.classList.toggle('hidden', expanded);
      btn.textContent = expanded ? 'Read less' : 'Read more';
      btn.setAttribute('aria-expanded', expanded);
    });
  })();
</script>

{% schema %}
{
  "name": {
    "en": "Title banner"
  },
  "settings": [
    {
            "type": "header",
            "content": "Help"
        },
        {
        "type": "paragraph",
        "content": "[Click here to follow an interactive Tutorial](https://vimeo.com/458187525)"
        },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Section layout",
      "options": [
        {"value": "default", "label": "Global default"},
        {"value": "boxed", "label": "Boxed"},
        {"value": "stretchBg", "label": "Full width background"},
        {"value": "stretchContent", "label": "Full width"}
      ],
      "default": "default"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Height",
      "default": 300,
      "min": 0,
      "max": 500,
      "step": 10,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "horizontalAlignment",
      "label": "Content alignment (left to right)",
      "options": [
        {"value": "start", "label": "Left"},
        {"value": "center", "label": "Center"},
        {"value": "end", "label": "Right"}
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "verticalAlignment",
      "label": "Content alignment (top to bottom)",
      "options": [
        {"value": "top", "label": "Top"},
        {"value": "middle", "label": "Middle"},
        {"value": "bottom", "label": "Bottom"}
      ],
      "default": "middle"
    },
    {
        "type": "header",
        "content": "Style"
    },
    {
      "type": "checkbox",
      "label": "Show Title",
      "default": true,
      "id": "showTitle"
    },
    {
      "type": "checkbox",
      "label": "Show number of products",
      "default": true,
      "id": "showNumber"
    },
    {
      "type": "select",
      "label": "Title size",
      "options": [
        {"value": "small", "label": "Small"},
        {"value": "base", "label": "Base"},
        {"value": "medium", "label": "Medium"},
        {"value": "big", "label": "Big"}
      ],
      "default": "medium",
      "id": "fontSize"
    },
    {
      "type": "checkbox",
      "label": "Show collection description",
      "default": false,
      "id": "showDescription"
    },
    {
      "type": "checkbox",
      "label": "Limit description to one row (read more)",
      "info": "Shows only the first row of content and adds a 'read more' button afterwards",
      "id": "truncateReadMore",
      "default": true
    },
    {
      "type": "range",
      "min": 0,
      "max": 1000,
      "step": 10,
      "label": "Truncate Description",
      "info": "Limits the amount of characters in the description. This is ignored if 'Read More' is turned on (above setting).",
      "id": "truncateDesc",
      "default": 0
    },
    {
      "type": "color",
      "id": "contentColor",
      "label": "Text color",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "color",
      "id": "fillColor",
      "label": "Background color",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "checkbox",
      "id": "useCollectionImage",
      "label": "Use collection's featured image as background",
      "default": true
    },
    {
        "type": "image_picker",
        "id": "defaultBackgroundImage",
        "label": "Default background image"
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "range",
      "id": "overlayOpacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "label": "Overlay opacity",
      "default": 0,
      "unit": "%"
    },
    {
      "type": "color",
      "id": "overlayColor",
      "label": "Overlay color",
      "default": "#000000"
    }
  ]
}
{% endschema %}