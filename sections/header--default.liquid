{%- if section.settings.layout == 'default' -%}
{%- assign layout = settings.baseLayout -%}
{%- else -%}
{%- assign layout = section.settings.layout -%}
{%- endif -%}

<style>
    {% render 'header__common-css', section: section, layout: layout %}
  
</style>

<div data-search-container class="search__container--abs" >
    <div class="search__overlay" onclick="BoosterTheme.ELEMENTS.closeSearch(this)"></div>
    <div class="search__container--wrapper">
        <h4 class="h-reset search__title">{{'general.search.heading' | t}} <span onclick="BoosterTheme.ELEMENTS.closeSearch(this)">{% render 'get-icon', icon: 'close' %}</span></h4>
        <form method="get" action="/search">
            <button type="submit" class="search__icon--submit">{% render 'get-icon', icon: 'search' %}</button>
            <input autocomplete="off" placeholder="{{'general.search.placeholder' | t }}" name="q" onfocus="BoosterTheme.ELEMENTS.openSearch(this)" type="search" data-search>
        </form>
    </div>
    <div class="search__results search__results--abs" data-search-suggest>
    </div>
</div>

<header class="page__header page__header--desktop {% if template == "index" and section.settings.transparent %}page__header--transparent{% endif %}">
    <div class="page__header--width">
        <div class="header__logo header__element--width">
            {% render 'logo' with section as section %}
        </div>
        <nav class="main__navigation main__navigation--center main__navigation--{{section.settings.hoverStyle}}" style="font-size:15px;">
            {% for link in linklists[section.settings.menuLinks].links %}
                {% if link.links.size > 0 %}{% capture submenu %}{% render 'header--link-submenu' with link as link %}{% endcapture %}{% else %}{% assign submenu = '' %}{% endif %}
                  {% if forloop.index == 10 %}
                  <span class="{% if link.links.size > 0 %} has_dropdown_menu_item {% endif %} nav__link__holder {% if link.active or link.child_active %}nav__link--active{% endif %} {% if submenu contains 'nav__submenu--regular' %}nav__link__holder--regular{% endif %}navdesk-off-menu">
                      <a class="nav__link nav__link--{{section.settings.hoverStyle}}" id="gocertify-popup-link" href="javascript:void(0)" onclick="gocertify.popup(); return false;">
                        {% render 'header--link-tag' with link.title as text %}
                      </a>
                   </span>
                   {% else %}
                   <span class="{% if link.links.size > 0 %} has_dropdown_menu_item {% endif %} nav__link__holder {% if link.active or link.child_active %}nav__link--active{% endif %} {% if submenu contains 'nav__submenu--regular' %}nav__link__holder--regular{% endif %}navdesk-{{link.title}}">
                      <a class="nav__link nav__link--{{section.settings.hoverStyle}}" href="{{link.url}}">{% render 'header--link-tag' with link.title as text %} {% if link.links.size > 0 %} {% comment %}<i class="uil uil-angle-down"></i> {% endcomment %}  <i class="uil desktoparrow"> {{ 'downarrow1.png' | asset_url | img_tag: 'downarrow' }} </i>  {% endif %} </a>
                      {{submenu}}
                  </span>
                  {% endif %}
            {% endfor %}
        </nav>
        <div class="header__element--width header__utility">
            {% render 'header__general--utility', showCart: section.settings.desktopCart %}
        </div>
    </div>
</header>


