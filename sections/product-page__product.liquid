<script>
  function updateQuantity(isIncreasing) {
    const qtyInput = document.querySelector('.quantity--input__input');
    let currentQty = parseInt(qtyInput.value, 10);

    if (isIncreasing) {
        qtyInput.value = currentQty + 1;
    } else {
        if (currentQty > 1) {
            qtyInput.value = currentQty - 1;
        }
    }
}

function toggleQuantity() {
    const checkbox = document.getElementById('save-10');
    const increaseBtn = document.getElementById('increaseBtn');
    
    if (checkbox.checked) {
        // If checked, click the increase button
        updateQuantity(true);
    } else {
        // If unchecked, click the decrease button
        updateQuantity(false);
    }
}
</script>
 <script>
{% if product.metafields.remfit.customcountdown.value != 'blank' %}
    // Selecting all countdown elements and iterating over them
    const countdowns = document.querySelectorAll('.countdown');
    countdowns.forEach((countdownElement) => {
      const daysElement = countdownElement.querySelector('.countdown__holder.days');
      const hoursElement = countdownElement.querySelector('.countdown__holder.hours');
      const minutesElement = countdownElement.querySelector('.countdown__holder.minutes');
      const secondsElement = countdownElement.querySelector('.countdown__holder.seconds');
      const endTime = countdownElement.dataset.ctKey;

      function updateCountdown() {
        const now = new Date();
        const countdownEndTime = new Date('{{ product.metafields.remfit.customcountdown.value }}').getTime();
        const timeDifference = countdownEndTime - now;

        if (timeDifference > 0) {
          const days = Math.floor(timeDifference / (1000 * 60 * 60 * 24));
          const hours = Math.floor((timeDifference % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
          const minutes = Math.floor((timeDifference % (1000 * 60 * 60)) / (1000 * 60));
          const seconds = Math.floor((timeDifference % (1000 * 60)) / 1000);

          daysElement.textContent = days.toString().padStart(2, '0');
          hoursElement.textContent = hours.toString().padStart(2, '0');
          minutesElement.textContent = minutes.toString().padStart(2, '0');
          secondsElement.textContent = seconds.toString().padStart(2, '0');
          setTimeout(updateCountdown, 1000);
        } else {
          daysElement.textContent = '00';
          hoursElement.textContent = '00';
          minutesElement.textContent = '00';
          secondsElement.textContent = '00';
        }
      }
      updateCountdown();
    });
  </script>

