<script>
const items = document.querySelectorAll('.accordion__item');

items.forEach(item => {
  item.addEventListener('click', (event) => {
    event.preventDefault();

    const isActive = item.classList.contains('active');
    items.forEach(sibling => sibling.classList.remove('active'));
    if (!isActive) {
      item.classList.add('active');
    }
  });
});

// Parent accordion groups: only one open at a time
const parentGroups = document.querySelectorAll('.product-accordion-group');
parentGroups.forEach(group => {
  group.addEventListener('toggle', () => {
    if (group.open) {
      parentGroups.forEach(other => {
        if (other !== group) {
          other.open = false;
        }
      });
    }
  });
});

// Smooth scroll with responsive offset
const discountLinks = document.querySelectorAll('.discount-section a');
const nightSleepAccordion = document.querySelector('#nightsleeptrial .accordion__item');

discountLinks.forEach(link => {
  link.addEventListener('click', (e) => {
    e.preventDefault();

    const target = document.querySelector('#nightsleeptrial');
    if (target) {
      // Responsive offset: larger on desktop, smaller on mobile
      let offset = window.innerWidth > 768 ? 200 : 50;

      // If you have a fixed header, you can measure it like this:
      const header = document.querySelector('header'); 
      if (header) {
        offset = header.offsetHeight + 120; // add some extra padding
      }

      const elementPosition = target.getBoundingClientRect().top + window.pageYOffset;
      const offsetPosition = elementPosition - offset;

      window.scrollTo({
        top: offsetPosition,
        behavior: 'smooth'
      });
    }

    items.forEach(item => item.classList.remove('active'));
    if (nightSleepAccordion) {
      nightSleepAccordion.classList.add('active');
    }
  });
});
</script>

<script>
document.addEventListener("DOMContentLoaded", function () {
  function wrapPriceText() {
    // Regex: £ followed by numbers/decimal, before " p/m"
    const regex = /(£\d+(?:\.\d{1,2})?)(?=\s*p\/m)/g;

    document.querySelectorAll("body *:not(script):not(style)").forEach(function (el) {
      if (el.children.length === 0 && el.textContent.includes("p/m")) {
        el.innerHTML = el.innerHTML.replace(regex, '<span class="custom-price">$1</span>');
      }
    });
  }

  // Run once on load
  wrapPriceText();

  // Observe DOM for new content
  const observer = new MutationObserver(function (mutations) {
    mutations.forEach(function (mutation) {
      mutation.addedNodes.forEach(function (node) {
        if (node.nodeType === 1) {
          wrapPriceText();
        }
      });
    });
  });

  observer.observe(document.body, {
    childList: true,
    subtree: true
  });

  // Add CSS for styled price
  var style = document.createElement("style");
  style.innerHTML = `
    #dividebuy-lowest {
      font-size: 16px !important;
      line-height: 140% !important;
    }
    .custom-price {
      font-size: 18px !important;
      font-weight: bold !important;
      color: #58327a !important;
    }
  `;
  document.head.appendChild(style);
});
</script>



