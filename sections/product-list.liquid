{% assign mobile = settings.cardMobile %}
{% if section.settings.cardDesktop == "default" %}
{% assign desktop = settings.cardDesktop %}
{% else %}
{% assign desktop = section.settings.cardDesktop %}
{% endif %}

{% paginate collection.products by section.settings.cardsPerPage %}
  {% for product in collection.products %}
    {% unless product.tags contains 'featured' %}
      <div class="center col-{{mobile}} col-md-{{desktop}} card--holder card-custom">
        {% render 'product-card-default' with product as product %}
      </div>
    {%endunless%}
  {% else %}
    <h2 class="h-reset font__size--medium font__family--title col-12 product-list__empty">{{'general.search.no_matches' |t}}</h2>
  {% endfor %}

  {% assign sid = 'shopify-section-' | append: section.id %}
  {% render 'pagination', paginate: paginate, section: sid %}
{% endpaginate %}

{% assign html = '' %}
<noscript id="JSON-filters">
{
  "filters": {
    {% for filter in collection.filters %}
      "{{filter.label|escape}}": [
        {% for f in filter.values %}
          {
            "active": {{f.active}},
            "count": {{f.count}},
            "label": {{f.label|json}},
            "value": {{f.value|json}},
            "urls": {
              "remove": "{{f.url_to_remove}}",
              "add": "{{f.url_to_add}}"
            }  
          }{% unless forloop.last %},{% endunless %}{% if f.active %}{% assign html = html | append: '<span data-filter-href="' | append: f.url_to_remove | append: '">Remove: ' | append: f.label | append: '</span>'%}{% endif %}
        {% endfor %}
      ]{% unless forloop.last %},{% endunless %}
    {% endfor %}
  },
  "html": {{html | json}},
  "count": {{collection.products_count}}
}
</noscript>

<style>
  .read-more-wrapper { position: relative; }
  .read-more-content {
    max-height: 350px;
    overflow: hidden;
    transition: max-height 0.4s ease;
  }
  .read-more-content.expanded { max-height: 2000px; }
  .read-more-fade {
    position: absolute;
    bottom: 30px;
    left: 0;
    width: 100%;
    height: 60px;
    background: linear-gradient(to bottom, transparent, #f9fcfe);
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .read-more-fade.hidden { opacity: 0; }
  .read-more-btn {
    background: none;
    border: none;
    color: inherit;
    font-weight: 600;
    cursor: pointer;
    padding: 8px 0;
    text-decoration: underline;
    font-size: inherit;
  }
  .read-more-btn:hover { opacity: 0.7; }
</style>

<script>
  (function () {
    var MAX = 350;

    function setup(wrapper) {
      if (wrapper.dataset.rmReady) return;
      wrapper.dataset.rmReady = '1';
      var content = wrapper.querySelector('.read-more-content');
      var btn = wrapper.querySelector('.read-more-btn');
      var fade = wrapper.querySelector('.read-more-fade');
      if (!content || !btn || !fade) return;
      if (content.scrollHeight <= MAX) {
        btn.style.display = 'none';
        fade.style.display = 'none';
        content.style.maxHeight = 'none';
      }
    }

    function init(root) {
      (root || document).querySelectorAll('.read-more-wrapper').forEach(setup);
    }

    // Toggle via delegation so it survives filter/sort re-renders
    document.addEventListener('click', function (e) {
      var btn = e.target.closest('.read-more-btn');
      if (!btn) return;
      var wrapper = btn.closest('.read-more-wrapper');
      var content = wrapper.querySelector('.read-more-content');
      var fade = wrapper.querySelector('.read-more-fade');
      var expanded = content.classList.toggle('expanded');
      fade.classList.toggle('hidden', expanded);
      btn.textContent = expanded ? 'Read less' : 'Read more';
      btn.setAttribute('aria-expanded', expanded);
    });

    init();

    // Booster re-renders the grid on filter/sort — re-init new cards
    var list = document.querySelector('.product__list');
    if (list && window.MutationObserver) {
      new MutationObserver(function () { init(list); }).observe(list, { childList: true });
    }
  })();
</script>

{% schema %}
  {
    "name": "Product list",
    "class": "row--product col-12 product__list top left-right-card",
    "settings": [
      {
            "type": "header",
            "content": "Help"
        },
        {
        "type": "paragraph",
        "content": "[Click here to follow an interactive Tutorial](https://vimeo.com/458187473)"
        },
        {
        "type": "select",
        "id": "cardDesktop",
        "label": "How many cards per row (Desktop)",
        "options": [
          {"value": "default", "label": "Global default"},
          {"value": "1-5", "label": "5"},
          {"value": "3", "label": "4"},
          {"value": "4", "label": "3"}
        ],
        "default": "default"
      },
      {
        "type": "range",
        "label": "How many cards per page",
        "id": "cardsPerPage",
        "default": 15,
        "min": 3,
        "max": 50,
        "step": 1
      }
    ] 
  }
{% endschema%}