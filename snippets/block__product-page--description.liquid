<div class="delivery-section">
  {% if product.metafields.custom.delivery_for_product %}
    <div class="delivery-info ">• {{ product.metafields.custom.delivery_for_product.value }}</div>
  {% endif %}
</div>

{% render 'bed-frame-selector' %}

{% if product.metafields.custom.image.value %}
  <div class="metaimg-pdp"><img src="{{ product.metafields.custom.image | file_url }}"></div>
{% endif %}
<div
  class="mattress_desc product__description {% if block.settings.noMargin or noMargin %}margin__bottom--reduced{%endif-%}"
  {{ block.shopify_attributes }}
>
  <span class="product__description--title">{{ block.settings.heading }}</span>
  <div><div class="read-more-wrapper">
  <div class="read-more-content" id="product-description-content">
    {{ product.description }}
  </div>
  <div class="read-more-fade" id="read-more-fade"></div>
  <button type="button" class="read-more-btn" id="read-more-btn" aria-expanded="false">

    Read more
  </button>
</div>

<style>
  .read-more-wrapper {
    position: relative;
  }
  .read-more-content {
    max-height: 350px;
    overflow: hidden;
    transition: max-height 0.4s ease;
  }
  .read-more-content.expanded {
    max-height: 2000px;
  }
  .read-more-fade {
    position: absolute;
    bottom: 30px;
    left: 0;
    width: 100%;
    height: 60px;
    background: linear-gradient(to bottom, transparent, #f9fcfe);
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .read-more-fade.hidden {
    opacity: 0;
  }
  .read-more-btn {
    background: none;
    border: none;
    color: inherit;
    font-weight: 600;
    cursor: pointer;
    padding: 8px 0;
    text-decoration: underline;
    font-size: inherit;
  }
  .read-more-btn:hover {
    opacity: 0.7;
  }
</style>

<script>
  (function() {
    var content = document.getElementById('product-description-content');
    var btn = document.getElementById('read-more-btn');
    var fade = document.getElementById('read-more-fade');

    // Only show toggle if content is taller than the collapsed height
    if (content.scrollHeight <= 350) {
      btn.style.display = 'none';
      fade.style.display = 'none';
      content.style.maxHeight = 'none';
      return;
    }

    btn.addEventListener('click', function() {
      var expanded = content.classList.toggle('expanded');
      fade.classList.toggle('hidden', expanded);
      btn.textContent = expanded ? 'Read less' : 'Read more';
      btn.setAttribute('aria-expanded', expanded);
    });
  })();
</script>
</div>
</div>
<div class="quicksize-tab-goup"></div>

{% comment %}
  <div class="product__description {% if block.settings.noMargin or noMargin %}margin__bottom--reduced{%endif-%}" {{block.shopify_attributes}}>
  <span class="product__description--title">{{block.settings.heading}}</span>
  <div>{{ product.description }}</div>
  </div>
  <div class="quicksize-tab-goup"></div>
{% endcomment %}
