<style>
  {%- unless block.settings.color contains "rgba(0,0,0,0)" -%}
  .product__price--{{block.id}} .product__price {
      color: {{block.settings.color}};
  }
  {%- endunless -%}

  {%- unless block.settings.newPriceColor contains "rgba(0,0,0,0)" -%}
  .product__price--{{block.id}} .product__price.product__price--sale {
      color: {{block.settings.newPriceColor}};
  }
  {%- endunless -%}

  {%- unless block.settings.oldPriceColor contains "rgba(0,0,0,0)" -%}
  .product__price--{{block.id}} .product__price--old {
      color: {{block.settings.oldPriceColor}};
  }
  {%- endunless -%}
</style>
{% comment %} This countdown code hide for mobile {% endcomment %}
  {% assign product_title_downcase = product.title | downcase %}
{% if product.metafields.remfitt.customcountdown.value != 'blank'
  and custom_countdown > today_date
  and settings.CustomCountdown
%}
  <div class="countdown-div hide-desktop">
    {% render 'block__product-page--countdown', product: product, block: block, view: view %}
  </div>
{% endif %}
{% assign product_qty = 0 %}
{% for variant in product.variants %}
  {% if variant.inventory_quantity > 0 %}
    {% assign product_qty = product_qty | plus: variant.inventory_quantity %}
  {% endif %}
{% endfor %}

{% if product_qty <= 0 %}
  {% if product.metafields.delayed.delivery != blank %}
    <input name="properties[Note]" type="hidden" value="{{ product.metafields.delayed.delivery.value }}">
  {% endif %}
  {% if product.metafields.sleep.trial != blank %}
    <input name="properties[Trial]" type="hidden" value="{{ product.metafields.sleep.trial.value }}">
  {% endif %}
{% endif %}

{% assign current_variant = product.selected_or_first_available_variant %}
{% assign s_type = block.settings.saleType | default: 'percent' %}
{% if template.name == 'product'
  and product.template_suffix != 'bed-frame'
  and product.template_suffix != 'topper'
  and product.template_suffix != 'pillows-template'
  and product.template_suffix != '500-cool-pillow-template'
  and product.template_suffix != 'snow-pillow-with-video'
  and product.template_suffix != 'protectors'
  and product.template_suffix != 'divan-bed'
  and product.template_suffix != 'pillow-protector'
%}
  {% if settings.mattressespromo_enable and settings.mattressespromo != blank %}
    <div class="discount-section">
      {{ settings.mattressespromo }}
    </div>
  {% endif %}
{% endif %}
{% if product.template_suffix == 'bed-frame' %}
  {% if settings.bedframespromo_enable and settings.bedframespromo != blank %}
    <div class="discount-section">
      {{ settings.bedframespromo }}
    </div>
  {% endif %}
{% endif %}
{% if product.template_suffix == 'divan-bed' %}
  {% if settings.divanbedspromo_enable and settings.divanbedspromo != blank %}
    <div class="discount-section">
      {{ settings.divanbedspromo }}
    </div>
  {% endif %}
{% endif %}
{% if product.template_suffix == 'topper' %}
  {% if settings.topperpromo_enable and settings.topperpromo != blank %}
    <div class="discount-section">
      {{ settings.topperpromo }}
    </div>
  {% endif %}
{% endif %}
{% if product.template_suffix == 'pillows-template'
  or product.template_suffix == '500-cool-pillow-template'
  or product.template_suffix == 'snow-pillow-with-video'
%}
  {% if settings.pillowspromo_enable and settings.pillowspromo != blank %}
    <div class="discount-section">
      {{ settings.pillowspromo }}
    </div>
  {% endif %}
{% endif %}
{% if product.template_suffix == 'protectors' or product.template_suffix == 'pillow-protector' %}
  {% if settings.protectorspromo_enable and settings.protectorspromo != blank %}
    <div class="discount-section">
      {{ settings.protectorspromo }}
    </div>
  {% endif %}
{% endif %}
{% render 'block__product-page--totalvalue', product: product %}
{% comment %}
    <span
    class="cdp-price"
    data-product-price="{{product.id}}"
    id="prod-price"
    class="product__price {% if currsale %}product__price--sale{% endif %} jsPrice"
  >
    {{- current_variant.price | money | strip_html -}}
  </span>
   {% assign min_price =  product.selected_or_first_available_variant.price | times: 0.01 %}
         {% assign disc_price =  product.selected_or_first_available_variant.price | times: 0.001 %}
         {% assign net_price =  min_price | minus: disc_price  %}
  {{ net_price | round: 2 }}
  with code
{% endcomment %}
{% comment %}
  {% if product.template_suffix == '' %}
    <div class="coupon-discount-price" bis_skin_checked="1">
      <span class="coupon-discount-price-div">
        {% assign min_price = product.selected_or_first_available_variant.price | times: 0.01 %}
        {% assign disc_price = product.selected_or_first_available_variant.price | times: 0.001 %}
        {% assign net_price = min_price | minus: disc_price %}
        <span class="cdp-price">£{{ net_price | round: 2 }}</span> with code
        <span class="cdp-coupon-code">EGGSTRA10</span>
        <span class="cdp-off-percentage" id="pdp-percentage-off">Apply 10% off</span>
      </span>
    </div>
  {% endif %}
{% endcomment %}


<div
  class="
    product__price--holder product__price--{{block.id}}
    font__family--{{-block.settings.fontFamily}} font__size--{{-block.settings.fontSize}}
    {% if block.settings.noMargin or noMargin %}margin__bottom--reduced{%endif-%}
  "
  {{ block.shopify_attributes }}
>
  {% if product.compare_at_price_min > 0 %}
    {% assign sale = true %}
    {% if current_variant.compare_at_price > 0 %}
      {% assign currsale = true %}
    {% else %}
      {% assign currsale = false %}
    {% endif %}
  {% else %}
    {% assign sale = false %}
    {% assign currsale = false %}
  {% endif %}
  <span
    data-product-price="{{product.id}}"
    id="prod-price"
    class="product__price {% if currsale %}product__price--sale{% endif %} jsPrice"
  >
    {{- current_variant.price | money | strip_html -}}
  </span>

  {% if product.template_suffix == blank and settings.enable_savings_widget %}
    {% unless product_title_downcase contains 'clearance' %}
    <span class="saving-badge">
      <a href="javascript:void(0);" class="saving_badge_tooltip_open">
        Total savings £<span class="total_discounted_amount"></span>
        <img src="https://cdn.shopify.com/s/files/1/0635/4432/8438/files/information.png?v=1744364942" alt="">
      </a>
    </span>
    <div class="saving_badge_tooltip_text saving_badge_tooltip">
      {% comment %}
        It’s calculated as the total value of the gift bundle items plus the extra discount you can apply to your order.
        The total savings may vary depending on the mattress and protector size you choose.
      {% endcomment %}
      {{ settings.savings_popup_text }}
    </div>
     {% endunless %}
  {% endif %}
   {% if product.template_suffix == 'natural-mattress' and settings.enable_savings_widget %}
    <span class="saving-badge">
      <a href="javascript:void(0);" class="saving_badge_tooltip_open">
        Total savings £<span class="total_discounted_amount"></span>
        <img src="https://cdn.shopify.com/s/files/1/0635/4432/8438/files/information.png?v=1744364942" alt="">
      </a>
    </span>
    <div class="saving_badge_tooltip_text saving_badge_tooltip">
      {% comment %}
        It’s calculated as the total value of the gift bundle items plus the extra discount you can apply to your order.
        The total savings may vary depending on the mattress and protector size you choose.
      {% endcomment %}
      {{ settings.savings_popup_text }}
    </div>
  {% endif %}
  {% comment %}
     {% if template != 'product' %}
    <span data-product-price-sale="{{product.id}}" class="product__price--old jsPrice">
      {%- if currsale %}{{ current_variant.compare_at_price | money | strip_html }}{% endif -%}
    </span>
    {% endif %}
  {% endcomment %}
  {% if sale %}
    {%- unless s_type == 'none' or sale == false %}
      <span
        data-tag-product="{{product.id}}"
        data-tag-type="{{s_type}}"
        class="tag tag--sale {% unless currsale %}hide{% endunless %} {% if s_type == 'amount' %}jsPrice{% endif %}"
      >
        {% if currsale %}
          {%- case s_type %}
            {% when 'percent' %}
              Save
              {{
                current_variant.price
                | minus: current_variant.compare_at_price
                | times: 100
                | divided_by: current_variant.compare_at_price
                | times: -1
              -}}
              % {% comment %}{{ 'general.tags.off' | t }}{% endcomment %}
            {% when 'amount' %}
              {{ current_variant.compare_at_price | minus: current_variant.price | money | strip_html }}
            {% when 'text' %}
              {{ 'general.tags.sale' | t }}
          {%- endcase -%}
        {% endif %}
      </span>
    {%- endunless -%}
  {% endif %}
</div>
{% if settings.enable_discount_widget %}
  {% if collection.handle == 'rem-fit-hybrid-mattresses'
    or collection.handle == 'elite-hybrid-mattresses'
    or collection.handle == 'rem-fit-remy-kidz-mattress'
    or collection.handle == 'all-mattresses'
    or product.template_suffix == ''
    or product.template_suffix == 'natural-mattress'
  %}
  {% unless product_title_downcase contains 'clearance' %}
    <div class="coupon-discount-price" bis_skin_checked="1">
      <span class="coupon-discount-price-div">
        {% assign min_price = product.selected_or_first_available_variant.price | times: 0.01 %}
        {% assign discount_rate = settings.percentage_discount | times: 0.01 %}
        {% assign disc_price = product.selected_or_first_available_variant.price | times: discount_rate | times: 0.01 %}
        {% assign net_price = min_price | minus: disc_price %}

        <span class="cdp-price">from £{{ net_price | round: 2 }}</span> with code
        <span class="cdp-coupon-code">{{ settings.discount_code }}</span>
        <span class="cdp-off-percentage">{{ settings.discount_button_text }}</span>
      </span>
    </div>
     {% endunless %}
  {% endif %}
{% endif %}
