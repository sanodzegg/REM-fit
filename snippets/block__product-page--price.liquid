      >or
      <span class="dicoprice">
        £
        {{-
          product.selected_or_first_available_variant.price
          | money_without_currency
          | divided_by: installment
          | round
        -}}
      </span>
      / m ({{ installment }} months) with
    </span>
    {% render 'klarna', icon-name: icon-name %}
    {% comment %}<span class="logo-or">or</span> {% render 'paypal-logo', icon-name: icon-name %}{% endcomment %}
  </div>
  {% comment %} This klarna code only for all mattress - code start here {% endcomment %}
  {% comment %} {% if product.template_suffix == '' or product.template_suffix == 'bed-frame' or product.template_suffix == 'topper' %} {% endcomment %}
  <div
    id="top-svg "
    class="installment-dicoprice klarna-installment {% if product.template_suffix == 'eco-mattresses'  %} eco-mattresses {% endif %}" style="display:none"
  >
    {% assign installment = 3 %}
    <span class="dicoprice-aslow"
      >or
      <span class="dicoprice">
        £
        {{- product.selected_or_first_available_variant.price | divided_by: 100 | divided_by: installment | round -}}
      </span>
      / m ({{ installment }} months) with
    </span>
    {% render 'klarna', icon-name: icon-name %}
    {% comment %}<span class="logo-or">or</span> {% render 'paypal-logo', icon-name: icon-name %}{% endcomment %}
  </div>
  {% comment %} {% endif %} {% endcomment %}
  {% comment %} This klarna code only for all mattress -  code end here {% endcomment %}
{% endif %}
