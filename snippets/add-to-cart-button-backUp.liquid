{% assign button = button | default: 'addToCart' %}
{% assign color = button | append: 'Color' %}
{% assign color = settings[color] %}
{% assign type = button | append: 'Type' %}
{% assign type = settings[type] %}
{%- assign icon = button | append: 'Icon' -%}
{%- assign icon = settings[icon] -%}

{% if price == 0 and settings.freeShipping %}
  {% assign text = settings.freeShippingText %}
{% else %}
  {% if text == blank %}
    {% assign text = 'general.buttons.add_to_cart' | t %}
  {% endif %}
{% endif %}

{% if variant %}
  {% unless quantity %}
    {% assign quantity = 1 %}
  {% endunless %}
{% endif %}
<script>
  function removeSpan() {
   document.querySelector('span[data-button-text]').style.color = 'transparent';
  }
</script>

{% if template contains 'product' %}
  {% comment %}
    {% assign current_day = '2023-05-28 12:30:00' | date: '%A' %}
    {% assign current_time = '2023-05-28 12:30:00' | date: '%s' %}
    {% assign cutoff_time = '2023-05-28' | date: '%Y-%m-%d 13:00:00' | date: '%s' %}
    <b>I'm testing this at {{ '2023-05-25 13:30:00' | date: format: 'short' }} </b>
  {% endcomment %}
  {% assign current_day = 'now' | date: '%A' %}
  {% assign current_time = 'now' | date: '%s' %}
  {% assign cutoff_time = 'now' | date: '%Y-%m-%d 13:00:00' | date: '%s' %}

  <!-- Calculate delivery dates for next day and the day after -->
  {% assign day_one = 1 | times: 24 | times: 60 | times: 60 %}
  {% assign next_day = current_time | plus: day_one | date: '%Y-%m-%d' %}
  {% assign next_day_s = next_day | date: '%s' %}

  {% assign day_second = 2 | times: 24 | times: 60 | times: 60 %}
  {% assign day_after_next_day = current_time | plus: day_second | date: '%Y-%m-%d' %}
  {% assign day_after_next_day_s = day_after_next_day | date: '%s' %}

  {% assign day_third = 3 | times: 24 | times: 60 | times: 60 %}
  {% assign day_after_next_to_next_day = current_time | plus: day_third | date: '%Y-%m-%d' %}
  {% assign day_after_next_to_next_day_s = day_after_next_to_next_day | date: '%s' %}

  {% assign day_fourth = 4 | times: 24 | times: 60 | times: 60 %}
  {% assign day_fourth = current_time | plus: day_fourth | date: '%Y-%m-%d' %}
  {% assign day_fourth_s = day_fourth | date: '%s' %}

  {% if current_day == 'Monday'
    or current_day == 'Tuesday'
    or current_day == 'Wednesday'
    or current_day == 'Thursday'
  %}
    {% if current_time < cutoff_time %}
      {% assign remaining_time = cutoff_time | minus: current_time %}
      {% assign remaining_hours = remaining_time | divided_by: 3600 %}
      {% assign remaining_minutes = remaining_time | modulo: 3600 | divided_by: 60 %}
      {% assign remaining_seconds = remaining_time | modulo: 60 %}

      <div class="base_style">
        <div class="btn_circle_green"></div>
        <p class="text_color_change">
          Order in {{ remaining_hours }}h {{ remaining_minutes }}min for
          <span id="next_day" class="text_bold">FREE</span> Delivery on {{ next_day | date: '%A, %B %d' }}
        </p>
      </div>

    {% else %}
      <!-- If ends for current_time < cutoff_time -->
      {% if current_day == 'Thursday' %}
        {% assign remaining_seconds = day_fourth_s | minus: current_time | round %}
        {% assign remaining_hours = remaining_seconds | divided_by: 3600 %}
        {% assign remaining_minutes = remaining_seconds | modulo: 3600 | divided_by: 60 %}
        {% assign remaining_seconds = remaining_seconds | modulo: 60 %}

        {% if remaining_hours > 0 or remaining_minutes > 0 or remaining_seconds > 0 %}
          {% assign delivery_date = day_fourth %}

          <div class="base_style">
            <div class="btn_circle_green"></div>
            <p class="text_color_change">
              Order in {{ remaining_hours }}h {{ remaining_minutes }}
              <span style="color:#167716;">
                for <span class="text_bold">FREE</span> Delivery on {{ delivery_date | date: '%A, %B %d' }}
              </span>
            </p>
          </div>
        {% endif %}
        <!-- current_day == 'Thursday' -->
      {% else %}
        {% assign day_one = 1 | times: 24 | times: 60 | times: 60 %}
        {% assign next_day = current_time | plus: day_one | date: '%Y-%m-%d' %}
        {% assign next_day_1pm = next_day | date: '%Y-%m-%d 13:00:00' | date: '%s' %}

        {% assign remaining_time = next_day_1pm | minus: current_time %}
        {% assign remaining_hours = remaining_time | divided_by: 3600 %}
        {% assign remaining_minutes = remaining_time | modulo: 3600 | divided_by: 60 %}
        {% assign remaining_seconds = remaining_time | modulo: 60 %}

        <div class="base_style">
          <div class="btn_circle_green"></div>
          <p class="text_color_change">
            Order in {{ remaining_hours }}h {{ remaining_minutes }}min
            {% comment %}till 1 pm of {{ next_day | date: '%A, %B %d' }} {% endcomment %} for
            <span id="day_after_next_day" class="text_bold">FREE</span> Delivery on
            {{ day_after_next_day | date: '%A, %B %d' }}
          </p>
        </div>
      {% endif %}
      <!-- end of current_day == 'Thursday' -->
    {% endif %}
  {% else %}
    <!-- end of current_day == 'Monday' or current_day == 'Tuesday' -->

    {% if current_day == 'Friday' %}
      {% assign remaining_seconds = day_after_next_to_next_day_s | minus: current_time | round %}
      {% assign delivery_date = day_fourth %}
    {% elsif current_day == 'Saturday' %}
      {% assign remaining_seconds = day_after_next_day_s | minus: current_time | round %}
            {% assign delivery_date = day_after_next_to_next_day %}
    {% else %}
      {% assign remaining_seconds = next_day_s | minus: current_time | round %}
        {% assign delivery_date = day_after_next_day %}
    {% endif %}
    {% assign remaining_hours = remaining_seconds | divided_by: 3600 %}
    {% assign remaining_minutes = remaining_seconds | modulo: 3600 | divided_by: 60 %}
    <div class="base_style">
      <div class="btn_circle_green"></div>
      <p class="text_color_change">
        Order in {{ remaining_hours }}h {{ remaining_minutes }}min
        <span style="color:#167716;">
          for <span class="text_bold">FREE</span> Delivery on {{ delivery_date | date: '%A, %B %d' }}
        </span>
      </p>
    </div>
  {% endif %}
{% endif %}
<!-- Template contains Product -->
<button
  id="my-button"
  data-buy-button="{{product.id}}"
  data-original-text="{{-text-}}"
  {{ disabled }}
  class="
    button button--{{-button}} button--{{-color}} {% if template.name == 'product'%} {% endif %}{% unless icon == 'none' %}button--icon{% endunless %}
    {% unless type == 'default' -%}
    button--{{-type}} button--{{-color-}}__{{-type}}
    {%- else -%}
    {% assign style = color | append: 'ButtonStyle' %}
    button--{{-settings[style]}} button--{{-color-}}__{{-settings[style]}}
    {%- endunless %} {{class-}}
  "

  {% unless disabled %}
    {% if settings.ajaxType == 'disabled' %}
      type="submit"
    {% else %}
      type="button"
      {% if variant %}
        onclick="document.querySelector('#my-button > span').style.fontSize = '0';BoosterTheme.cart.addToCartJSON(event, {items: [{id: {{variant}}, quantity: {{quantity}}}]}); this.classList.add('lds-dual-ring'); "
      {% else %}
        {% comment %}
        onclick="document.querySelector('#my-button > span').style.fontSize = '0';BoosterTheme.cart.addToCart(event); this.classList.add('lds-dual-ring');"
        {% endcomment %}
        onclick="document.querySelector('#my-button > span').style.fontSize = '0'; BoosterTheme.cart.addToCart(event); this.classList.add('lds-dual-ring'); 
        setTimeout(function() { 
        this.classList.remove('lds-dual-ring'); 
        document.querySelector('#my-button > span[data-button-text]').style.fontSize = '18px'; 
        }.bind(this), 1000);"
      {% endif %}
    {% endif %}
  {% endunless -%}
>
  {% unless icon == 'none' %}
    {% render 'get-icon' with icon as icon %}
  {% endunless %}
  <span data-button-text>{{- text -}}</span>
</button>
