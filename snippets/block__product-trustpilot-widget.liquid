 {% for block in section.blocks %}
  {% if block.type == "trustpilotwidget" %}
    <div class="trustpilot-widget-block">
      <a href="https://www.trustpilot.com/review/shop.rem-fit.co.uk" target="_blank">
        <span class="trustpilot-rating-summary">{{settings.rating-summary}}</span>
        <span class="trustpilot-rating-numbers">({{settings.rating-value}})</span>
        <img class="trustpilot-rating-stars" src="https://cdn.shopify.com/s/files/1/0635/4432/8438/files/trustpilot_ratings_img.png?v=1741608082" alt="" />
        <span class="trustpilot-rating-reviews-number">{{settings.review-text}}</span>
        {% comment %}
          <img class="trustpilot-logo tp-desktop-logo" src="https://cdn.shopify.com/s/files/1/0635/4432/8438/files/trustpilot_brand_logo.png?v=1741608082" alt="" />
          <img class="trustpilot-logo tp-mobile-logo" src="https://cdn.shopify.com/s/files/1/0635/4432/8438/files/trustpilot-white-logo.png?v=1741768075" alt="" />
        {% endcomment %}
      </a>
    </div>
  {% endif %}
{% endfor %}