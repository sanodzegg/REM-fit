
{% assign today_date = 'now' | date: '%s' %}
{% assign count_down_date = settings.countdownTime | date: '%s' %}
{% assign custom_countdown = product.metafields.remfit.customcountdown.value | date: '%s' %}

{% if settings.countdown and count_down_date > today_date %}
  <div
    class="product__countdown--holder product__countdown--{{-block.settings.style}} {% if block.settings.noMargin or noMargin %}margin__bottom--reduced{%endif-%} gallery-countdown"
    {{ block.shopify_attributes }}
  >
    {% if block.settings.style == 'compact' or view == 'marketplace' %}
      <div data-countdown data-ct-key="{{product.id}}" class="countdown product__countdown">
        <span class="countdown__title">
          <!--{{- block.settings['title-'] }}-->
         <!-- New Year Sale Ends: -->
          {{ settings.countdownMobileTitle }}
        </span>
        <span class="countdown__holder"
          ><span class="days">00</span><br>
          {{ 'general.countdown.days' | t -}}
        </span>
        <span class="countdown__holder"
          ><span class="hours">00</span><br>
          {{ 'general.countdown.hours' | t -}}
        </span>
        <span class="countdown__holder"
          ><span class="minutes">00</span><br>
          {{ 'general.countdown.minutes' | t -}}
        </span>
        <span class="countdown__holder"
          ><span class="seconds">00</span><br>
          {{ 'general.countdown.seconds' | t -}}
        </span>
      </div>
      {%- capture originalPrice -%}<span class="countdown__original-price jsPrice">{{product.compare_at_price_max | money | strip_html}}</span>{%- endcapture -%}
      <p class="p-reset countdown__warning">
        {{- block.settings.text | replace: '%price%', originalPrice -}}
      </p>
    {% else %}
      <div class="customcount-down">
        <span class="countdown__title">{{- block.settings['title-'] }}</span>
        {%- capture originalPrice -%}<span class="countdown__original-price jsPrice">{{product.compare_at_price_max | money | strip_html}}</span>{%- endcapture -%}
        <p class="p-reset countdown__warning">
          {{- block.settings.text | replace: '%price%', originalPrice -}}
        </p>
      </div>
      <div data-countdown data-ct-key="{{product.id}}" class="countdown product__countdown gallery-below-countd">
        <span class="countdown__title">
<!-- New Year Sale Ends: -->
 {{ settings.countdownDeskTitle }}
</span>
        <span class="countdown__holder"
          ><span class="days">00</span><br>
          {{ 'general.countdown.days' | t -}}
        </span>
        <span class="countdown__holder"
          ><span class="hours">00</span><br>
          {{ 'general.countdown.hours' | t -}}
        </span>
        <span class="countdown__holder"
          ><span class="minutes">00</span><br>
          {{ 'general.countdown.minutes' | t -}}
        </span>
        <span class="countdown__holder"
          ><span class="seconds">00</span><br>
          {{ 'general.countdown.seconds' | t -}}
        </span>
      </div>
    {% endif %}
  </div>
{% endif %}
{% if product.metafields.remfitt.customcountdown.value != 'blank'
  and custom_countdown > today_date
  and settings.CustomCountdown
%}
  <div data-ct-key="{{product.id}}" class="countdown product__countdown gallery-below-countd">
    <span class="countdown__title">
<!-- New Year Sale Ends: --> {{ settings.countdownDeskTitle }}
</span>
    <div>
      <span class="countdown__holder days">00</span><br>
      <span class="countdown_text">{{ 'general.countdown.days' | t -}}</span>
    </div>
    <div>
      <span class="countdown__holder hours">00</span><br>
      <span class="countdown_text">{{ 'general.countdown.hours' | t -}}</span>
    </div>
    <div>
      <span class="countdown__holder minutes">00</span><br>
      <span class="countdown_text">{{ 'general.countdown.minutes' | t -}}</span>
    </div>
    <div>
      <span class="countdown__holder seconds">00</span><br>
      <span class="countdown_text">{{ 'general.countdown.seconds' | t -}}</span>
    </div>
  </div>
{% endif %}
