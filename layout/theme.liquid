      <script
        type="text/javascript"
      >
               $(document).ready(function() {
    function updateDiscountedPrice() {
        var productPrice = $('#prod-price').text().replace('£', '').replace(/[^0-9.]/g, '');
        productPrice = parseFloat(productPrice);
    
        if (isNaN(productPrice)) {
            console.log("Invalid product price");
            return;
        }
    
        // Define dynamic divisor values
        const divisorUnder50 = 3;
        const divisor50To250 = 6;
        const divisor250To450 = 9;
        const divisorAbove450 = 12;
    
        let divideByPrice;
        let appliedDivisor;
    
        // Determine the divisor and calculate the divided price
        if (productPrice < 50) {
            appliedDivisor = divisorUnder50;
        } else if (productPrice >= 50 && productPrice < 250) {
            appliedDivisor = divisor50To250;
        } else if (productPrice >= 250 && productPrice < 450) {
            appliedDivisor = divisor250To450;
        } else {
            appliedDivisor = divisorAbove450;
        }
    
        divideByPrice = Math.round(productPrice / appliedDivisor);
        appliedDivisor = Math.round(appliedDivisor); // Ensure divisor is an integer
    
        var curr = "£";
        var amountText = `${curr}${divideByPrice} `;
        var monthsText = `/ m (${appliedDivisor} months)`;
    
        // Update the content of the respective elements
        $(".divideByPrice").text(amountText);
        $(".installmentMonths").text(monthsText);
    
        console.log(`Divided by: ${appliedDivisor}, Result: ${divideByPrice}`);
         // ✅ New code: Handle multiple .cdp-price spans
        var cdpPriceSpans = $(".cdp-price");
        var dynamicDiscountRate = {{ discount_rate }};

         if (cdpPriceSpans.length > 0) {
          var discountedPrice = productPrice * (1 - dynamicDiscountRate);
          discountedPrice = discountedPrice.toFixed(2);
      
          cdpPriceSpans.each(function() {
          $(this).text(`£${discountedPrice}`);
            });
          }

    }
    
    $('select').on('change', function() {
        setTimeout(updateDiscountedPrice, 500);
    });
    
    updateDiscountedPrice();
});
      </script>
