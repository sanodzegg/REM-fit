            setTimeout(function() {
              const url = window.location.href;
              const variantIndex = url.indexOf('variant=');

              if (variantIndex !== -1) {
                const variantValue = url.substring(variantIndex + 'variant='.length);
                const matchedElement = $('#' + variantValue);

